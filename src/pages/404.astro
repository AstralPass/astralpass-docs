---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
	frontmatter={{
		title: 'Page not found',
		description: 'The page you requested does not exist or may have moved.',
		template: 'splash',
	}}
>
	<Fragment slot="hero">
		<div class="hero-stack">
			<img src="/brand/logo-white.png" alt="AstralPass" class="hero-logo" />
			<p class="tagline">Looks like this page drifted out of the galaxy.</p>
			<div class="actions">
				<a class="sl-link-button primary" href="/">Go to the docs home</a>
				<a class="sl-link-button secondary" href="/core/getting-started/">Start with Getting Started</a>
			</div>
		</div>
	</Fragment>

	<h2>What you can do next</h2>
	<ul>
		<li><a href="/core/about-astralpass/">About AstralPass</a> for the big picture</li>
		<li><a href="/core/troubleshooting/">Troubleshooting</a> if you were trying to solve a wallet or role issue</li>
		<li><a href="/star-atlas/why-astralpass-for-star-atlas/">Why AstralPass for Star Atlas</a> for DAC or Player Profile context</li>
	</ul>
</StarlightPage>

<style>
	.hero-stack {
		display: grid;
		gap: 1rem;
		justify-items: start;
	}

	.hero-logo {
		max-width: 14rem;
		width: 100%;
		height: auto;
		padding: 1rem;
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(7, 12, 20, 0.92), rgba(18, 28, 43, 0.96));
		box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.3);
	}

	.tagline {
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
</style>
